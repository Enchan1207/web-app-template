{
    "name": "app",
    "type": "module",
    "scripts": {
        "dev": "vite --mode=development",
        "build": "tsc -b && vite build",
        "test": "vitest",
        "wrangler": "wrangler",
        "deploy:stg": "vite build --mode=staging && wrangler --env=staging deploy",
        "deploy:stg:secret": "wrangler --env=staging secret bulk .env.staging.local",
        "deploy:prod": "vite build --mode=production && wrangler --env=production deploy",
        "deploy:prod:secret": "wrangler --env=production secret bulk .env.production.local",
        "migrate:generate": "drizzle-kit generate",
        "migrate:local": "MODE=development drizzle-kit migrate",
        "migrate:stg": "MODE=staging drizzle-kit migrate",
        "migrate:prod": "MODE=production drizzle-kit migrate"
    },
    "dependencies": {
        "@hono/zod-validator": "^0.7.6",
        "@libsql/client": "^0.17.0",
        "@tailwindcss/vite": "^4.2.0",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-query-devtools": "^5.91.3",
        "@tanstack/react-router": "^1.162.2",
        "@tanstack/react-router-devtools": "^1.162.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-orm": "^0.45.1",
        "hono": "^4.12.1",
        "lucide-react": "^0.575.0",
        "next-themes": "^0.4.6",
        "openid-client": "^6.8.2",
        "radix-ui": "^1.4.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "shadcn": "^3.8.5",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.0",
        "ts-pattern": "^5.9.0",
        "tslib": "^2.8.1",
        "tw-animate-css": "^1.4.0",
        "ulid": "^3.0.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.25.2",
        "@cloudflare/vitest-pool-workers": "^0.12.14",
        "@cloudflare/workers-types": "^4.20260228.0",
        "@tanstack/router-plugin": "^1.162.2",
        "@types/pg": "^8.16.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "drizzle-kit": "^0.31.9",
        "vite": "^7.3.1",
        "wrangler": "^4.67.0"
    }
}